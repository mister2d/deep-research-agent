# Copy to .env and fill in for your infra. .envrc loads this via dotenv_if_exists.
# .env is gitignored — never commit real endpoints or tokens.

# --- LLM / thinking endpoint (OpenAI-compatible) ---
OPENAI_API_BASE=http://localhost:8080/v1
OPENAI_API_KEY=dummy
OPENAI_MODEL=local-model

# --- Web search (SearXNG) ---
# Base URL of the SearXNG instance; the app appends /search automatically.
SEARXNG_URL=http://localhost:8888

# --- Content fetching (Crawl4AI) ---
# Base URL of the self-hosted Crawl4AI REST service. When unset, the agent
# falls back to a plain httpx + BeautifulSoup fetch.
CRAWL4AI_URL=http://localhost:11235
# Auth token for Crawl4AI (defaults to "dummy" if unset).
CRAWL4AI_AUTH_TOKEN=dummy

# --- Document extraction (Apache Tika) ---
# Base URL of the Tika server; PDFs/Office/EPUB/RTF/images are routed here.
TIKA_BASE_URL=http://localhost:9998

# --- Web search skill ---
# Directory of the hybrid-web-search skill (the one containing run-json.mjs).
HYBRID_SEARCH_SKILL_DIR=/path/to/skills/hybrid-web-search

# Optional hybrid-web-search pipeline tuning. These may be set here as ambient
# env vars OR under settings.web_search in config.yaml (config.yaml wins). The
# shipped config template already enables the deep-research-grade values below;
# these env vars are for tuning without a config.yaml. When unset in both, the
# skill's scout-grade defaults apply (3/5/0.5/512/8000).
# HYBRID_SEARCH_MAX_CRAWL_URLS=5
# HYBRID_SEARCH_MAX_OUTPUT_CHUNKS=8
# HYBRID_SEARCH_CHUNK_TOKEN_TARGET=512
# HYBRID_SEARCH_CRAWL_SCORE_THRESHOLD=0.0
# HYBRID_SEARCH_TIMEOUT_MS=20000
